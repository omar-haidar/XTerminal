<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.XTerminal" parent="Theme.Material3.DynamicColors.DayNight.NoActionBar">
        <item name="android:statusBarColor">?attr/colorSurface</item>
        <item name="android:navigationBarColor">?attr/colorSurface</item>
        <item name="android:windowLightStatusBar">?isLightTheme</item>
        <item name="android:windowLightNavigationBar" tools:ignore="NewApi">?isLightTheme</item>
        <item name="fontFamily">@font/outfit_regular</item>
        <item name="android:fontFamily">@font/outfit_regular</item>
        <item name="android:forceDarkAllowed" tools:ignore="NewApi">false</item>
    </style>

    <style name="Theme.XTerminal" parent="Base.Theme.XTerminal" />
</resources>